{
  "name": "Hollow Signal",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Shared": { "$path": "src/shared" }
    },
    "ServerScriptService": {
      "HollowSignalServer": { "$path": "src/server" }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "HollowSignalClient": { "$path": "src/client" }
      }
    },
    "Workspace": {
      "$properties": { "StreamingEnabled": true }
    },
    "Lighting": {
      "$properties": {
        "Technology": "Future",
        "GlobalShadows": true,
        "Brightness": 2
      }
    }
  }
}
